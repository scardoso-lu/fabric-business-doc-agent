# ── Provider ──────────────────────────────────────────────────
# Choose one: anthropic | openai | ollama | local
#
#   local — uses the Claude CLI installed on this machine (claude -p).
#           No API key or embedding service required. RAG is skipped;
#           Claude reasons over the full content summary directly.
LLM_PROVIDER=local

# Model to use — leave blank to use the provider default:
#   anthropic → claude-sonnet-4-6
#   openai    → gpt-4o-mini
#   ollama    → llama3.2
#   local     → (ignored — model is determined by the Claude CLI config)
LLM_MODEL=

# ── API keys (only needed for the chosen provider) ────────────
# Not required when LLM_PROVIDER=local.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Ollama (only needed when LLM_PROVIDER=ollama) ─────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding model for RAG (optional) ────────────────────────
# Defaults: openai → text-embedding-3-small | ollama → nomic-embed-text
# Anthropic and local have no embeddings API — RAG is skipped automatically.
# EMBEDDING_MODEL=

# ── Artifact types (optional) ────────────────────────────────
# Comma-separated list of artifact types to scan.
# Supported values: pipeline, notebook, dataflow, powerautomate
# Default scans Fabric artifacts only; add powerautomate to include Power Automate flows.
# ARTIFACT_TYPES=pipeline,notebook,dataflow,powerautomate

# ── Source repository (optional) ──────────────────────────────
# GitHub repo to clone before scanning. When set, --src defaults to the clone root.
# GITHUB_REPO_URL=https://github.com/your-org/your-repo

# ── Output directory (optional) ───────────────────────────────
# OUTPUT_DIR=./output

# ── Prompt customisation (optional) ──────────────────────────
# Path to a markdown file containing per-section prompt overrides.
# Defaults to prompts.md in the project root. Set to "" to use built-in defaults.
# PROMPTS_FILE=./prompts.md

# ── Company / project context (optional) ──────────────────────
# Path to a plain-text file describing the organisation, project, or domain.
# Content is appended to the system prompt so the LLM can produce more
# specific and relevant documentation.
# CONTEXT_FILE=./context.txt

# ── Purpose enrichment (optional) ────────────────────────────
# When set, the agent searches for related work items / pull requests before
# generating the Purpose section. If nothing is found it falls back to
# inferring the purpose from the artifact's data flow.
#
# Jira — set all three to enable:
# JIRA_URL=https://mycompany.atlassian.net
# JIRA_EMAIL=user@example.com
# JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JIRA_PROJECT_KEY=PROJ              # optional: restrict search to this project
#
# Azure DevOps — reuses AZDO_ORG / AZDO_PROJECT / AZDO_PAT below.
# No extra variables needed; work items and PRs are searched automatically
# when those three variables are set.

# ── Wiki publishing ───────────────────────────────────────────
# Set PUBLISH_WIKI=true to push generated docs to a wiki.
# WIKI_TYPE selects the backend: azuredevops (default) or confluence.
# PUBLISH_WIKI=false
# WIKI_TYPE=azuredevops

# Azure DevOps (WIKI_TYPE=azuredevops)
# AZDO_ORG=my-organisation
# AZDO_PROJECT=my-project
# AZDO_WIKI_ID=my-project.wiki        # wiki name shown in the Azure DevOps URL
# AZDO_PAT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZDO_WIKI_PATH_PREFIX=/Fabric Docs  # optional: place all pages under this path

# Confluence (WIKI_TYPE=confluence)
# CONFLUENCE_URL=https://mycompany.atlassian.net
# CONFLUENCE_SPACE_KEY=FABRIC
# CONFLUENCE_EMAIL=user@example.com
# CONFLUENCE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CONFLUENCE_PARENT_PAGE_ID=           # optional: ID of the parent page
